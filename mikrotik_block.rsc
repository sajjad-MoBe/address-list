# Firewall rules to drop traffic to these lists
/ip firewall filter
add action=drop chain=forward dst-address-list=Block_Social comment="Block Social Media"
add action=drop chain=forward dst-address-list=Block_Updates comment="Block Updates"
add action=drop chain=forward dst-address-list=Block_Adult comment="Block Adult Content"
add action=drop chain=forward dst-address-list=Block_Bandwidth_Hogs comment="Block Gaming/Streaming Hogs"
